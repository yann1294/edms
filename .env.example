# API
API_PORT=3000
API_BASE_PATH=/api/v1
NODE_ENV=development

# Auth (JWT)
# NOTE: Do not commit real secrets. Use a secure secret in production.
AUTH_JWT_SECRET=change-me
# Optional (default: 3600)
AUTH_JWT_EXPIRES_IN_SECONDS=3600

# Dev-only bootstrap user (enabled only when NODE_ENV=development)
# Use bcrypt hash of a password; never store raw passwords.
# AUTH_BOOTSTRAP_USER_ID=bootstrap-user
# AUTH_BOOTSTRAP_USER_EMAIL=admin@example.com
# AUTH_BOOTSTRAP_USER_PASSWORD_HASH=$2b$10$...
# AUTH_BOOTSTRAP_USER_FIRST_NAME=Bootstrap
# AUTH_BOOTSTRAP_USER_LAST_NAME=User
# AUTH_BOOTSTRAP_USER_STATUS=active

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=edms
DB_PASSWORD=edms
DB_NAME=edms

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# S3-compatible storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=edms
S3_SECRET_KEY=edmssecret
S3_BUCKET=edms

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
